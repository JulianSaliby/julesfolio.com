---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { asset } from '../../lib/assets';
import ProjectCard from '../../components/ProjectCard.astro';

const order = { hero: 0, featured: 1, standard: 2, minor: 3 };
const projects = (await getCollection('projects', ({ data }) => data.disciplines.includes('photography')))
  .sort((a, b) => order[a.data.weight] - order[b.data.weight] || b.data.year - a.data.year);

// Commercial Photography, Business Portrait, and Personal Photographs are now
// real case studies in the `projects` collection — nothing left in "coming soon".
const upcoming: { title: string; year: number; cover: string }[] = [];
---

<Base title="Photography">
  <header class="container gallery-head">
    <p class="meta">Category</p>
    <h1>Photography</h1>
  </header>

  <section class="container grid">
    {projects.map((p, i) => (
      <ProjectCard
        large={p.data.weight === 'hero'}
        href={`/projects/${p.id}`}
        title={p.data.title}
        meta={`${p.data.year}`}
        cover={p.data.cover}
      />
    ))}
    {upcoming.map((u) => (
      <div class="card-soon reveal">
        <figure class="soon-media">
          <Image src={asset(u.cover)} alt={u.title} widths={[600, 1200]} sizes="(max-width: 820px) 100vw, 50vw" />
        </figure>
        <div class="soon-caption">
          <h3 class="soon-title">{u.title}</h3>
          <p class="meta">{u.year} · Coming soon</p>
        </div>
      </div>
    ))}
  </section>
</Base>

<style>
  .gallery-head { padding-top: 8rem; }
  .gallery-head h1 { font-size: var(--text-2xl); margin-top: 0.5rem; }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    margin-top: 3rem;
  }
  .grid > :global(.card.large), .grid > :global(a.large) { grid-column: 1 / -1; }
  .card-soon { opacity: 0.55; }
  .soon-media { overflow: hidden; background: var(--bg-elevated); aspect-ratio: 3 / 2; }
  .soon-media :global(img) { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.8); }
  .soon-caption { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-top: 0.9rem; }
  .soon-title { font-size: var(--text-base); font-weight: 600; }
  @media (max-width: 680px) { .grid { grid-template-columns: 1fr; } }
</style>
