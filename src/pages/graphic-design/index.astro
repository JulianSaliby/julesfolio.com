---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { asset, hasAsset } from '../../lib/assets';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const order = { hero: 0, featured: 1, standard: 2, minor: 3 };
const projects = (await getCollection('projects', ({ data }) => data.disciplines.includes('graphic-design')))
  .sort((a, b) => order[a.data.weight] - order[b.data.weight] || b.data.year - a.data.year);

// Olivera and Graphic Design Posters are now real case studies in the
// `projects` collection — nothing left in "coming soon".
const upcoming: { title: string; year: number; cover: string }[] = [];
---

<Base title="Graphic Design" description="Graphic design by Julian Saliby — brand identities, logo systems, and print.">
  <header class="container gallery-head">
    <p class="meta">Category</p>
    <h1>Graphic Design</h1>
    <p class="lede">Brand identities, logo systems, and print — from wordmark to guidelines to signage on the street.</p>
  </header>

  <section class="container section">
    <div class="proj-grid">
      {projects.map((p) => (
        <ProjectCard
          large={p.data.weight === 'hero'}
          href={`/projects/${p.id}`}
          title={p.data.title}
          meta={`${p.data.year}`}
          cover={p.data.cover}
        />
      ))}
    </div>
  </section>

  {upcoming.length > 0 && (
    <section class="container grid">
      {upcoming.map((u) => (
        <div class="card-soon reveal">
          <figure class="soon-media">
            <Image src={asset(u.cover)} alt={u.title} widths={[600, 1200]} sizes="(max-width: 820px) 100vw, 33vw" />
          </figure>
          <div class="soon-caption">
            <h3 class="soon-title">{u.title}</h3>
            <p class="meta">{u.year} · Coming soon</p>
          </div>
        </div>
      ))}
    </section>
  )}
</Base>

<style>
  .gallery-head { padding-top: 8rem; }
  .gallery-head h1 { font-size: var(--text-2xl); margin-block: 0.5rem 1rem; }
  .lede { color: var(--text-secondary); max-width: 52ch; }
  .proj-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.5rem, 3vw, 2.5rem); }
  .proj-grid > :global(.card.large) { grid-column: 1 / -1; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.25rem, 2.5vw, 2rem); margin-top: 3rem; }
  .card-soon { opacity: 0.6; }
  .soon-media { overflow: hidden; background: var(--bg-elevated); aspect-ratio: 4 / 3; }
  .soon-media :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .soon-caption { margin-top: 0.8rem; }
  .soon-title { font-size: var(--text-base); font-weight: 600; }
  @media (max-width: 820px) { .grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 680px) { .proj-grid { grid-template-columns: 1fr; } }
  @media (max-width: 560px) { .grid { grid-template-columns: 1fr; } }
</style>
