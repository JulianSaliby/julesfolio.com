---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import { asset } from '../lib/assets';
import { getCollection } from 'astro:content';

// Flagships — featured on the home page AND inside each category gallery
// they contribute to. Presented as portfolio cards (Julian's work), never
// styled as the client's own site.
const featured = (await getCollection('projects', ({ data }) => data.featured_home))
  .sort((a, b) => (a.data.home_order ?? 99) - (b.data.home_order ?? 99));

const labels = {
  videography: 'Videography',
  photography: 'Photography',
  'graphic-design': 'Graphic Design',
  'industrial-design': 'Industrial Design',
};
const span = (p) => p.data.disciplines.map((d) => labels[d]).join(' · ');

const categories = [
  {
    href: '/videography',
    label: 'Videography',
    sub: 'Cinematic · commercial · short form',
    cover: 'covers/videography-1',
    alt: 'Videography by Julian Saliby',
  },
  {
    href: '/photography',
    label: 'Photography',
    sub: 'Automotive · architectural · commercial',
    cover: 'covers/photo',
    alt: 'Photography by Julian Saliby',
  },
  {
    href: '/graphic-design',
    label: 'Graphic Design',
    sub: 'Identity · logo systems · print',
    cover: 'covers/graphic-design-posters',
    alt: 'Graphic design by Julian Saliby',
  },
  {
    href: '/industrial-design',
    label: 'Industrial Design',
    sub: 'Products · furniture · capstone',
    cover: 'covers/industrial-design-projects',
    alt: 'Industrial design by Julian Saliby',
  },
];
---

<Base>
  <!-- Full-screen video hero -->
  <section class="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/media/portfolio-header-poster.jpg"
    >
      <source src="/media/portfolio-header.mp4" type="video/mp4" />
    </video>
    <div class="hero-scrim"></div>
    <div class="container hero-content">
      <h1 class="hero-title">Julesfolio</h1>
      <p class="hero-line">
        Industrial designer, photographer, and videographer — one eye for
        product, brand, and image, across every medium a project needs.
      </p>
    </div>
    <div class="hero-cue" aria-hidden="true"><span>Scroll</span></div>
  </section>

  <!-- Featured Work — expanding panels; hover to reveal each project -->
  <section class="container section feat-section">
    <p class="meta feat-label">Featured Work</p>
    <div class="feat-panels">
      {featured.map((p, i) => (
        <a href={`/projects/${p.id}`} class="feat-panel reveal">
          <figure class="feat-panel-media">
            <Image
              src={asset(p.data.cover)}
              alt={`${p.data.title} — work by Julian Saliby`}
              widths={[600, 1000, 1400]}
              sizes="(max-width: 820px) 100vw, 55vw"
              loading={i < 2 ? 'eager' : 'lazy'}
            />
          </figure>
          <div class="feat-panel-cap">
            <h2 class="feat-panel-title">{p.data.title}</h2>
            <p class="meta feat-panel-meta">{span(p)} · {p.data.year}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Browse by category — a clear path in for single-discipline visitors -->
  <section class="container section">
    <p class="meta" style="margin-bottom:1.5rem">Browse by category</p>
    <div class="cats">
      {categories.map((c) => (
        <a href={c.href} class="cat reveal">
          <figure class="cat-media">
            <Image src={asset(c.cover)} alt={c.alt} widths={[600, 900, 1200]} sizes="(max-width: 820px) 100vw, 25vw" loading="lazy" />
          </figure>
          <div class="cat-overlay">
            <div>
              <h2 class="cat-name">{c.label}</h2>
              <p class="cat-sub">{c.sub}</p>
            </div>
            <span class="cat-arrow" aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Quiet footer CTA -->
  <section class="container section home-cta reveal">
    <p class="meta">Julian Saliby — design · photo · film</p>
    <p class="cta-line">
      <a href="/about">About</a> · <a href="/contact">Get in touch</a>
    </p>
  </section>
</Base>

<style>
  /* ---- Full-screen video hero ---- */
  .hero {
    position: relative;
    height: 100vh;
    height: 100svh;
    min-height: 560px;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(10, 10, 11, 0.92) 0%, rgba(10, 10, 11, 0.25) 42%, rgba(10, 10, 11, 0.55) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-bottom: clamp(3.5rem, 12vh, 8rem);
  }
  .hero-title {
    font-size: var(--text-hero);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .hero-line {
    margin-top: 1.15rem;
    color: var(--text-secondary);
    max-width: 48ch;
    font-size: var(--text-lg);
    line-height: 1.4;
  }
  .hero-cue {
    position: absolute;
    z-index: 2;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--text-tertiary);
  }
  .hero-cue span {
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    animation: cue 2.4s var(--ease) infinite;
  }
  @keyframes cue { 0%, 100% { opacity: 0.35; } 50% { opacity: 0.9; } }

  /* ---- Featured Work — expanding panels ---- */
  .feat-section { margin-top: 0; }
  .feat-label { margin-bottom: 1.5rem; }

  .feat-panels {
    display: flex;
    gap: 0.5rem;
    height: clamp(360px, 62vh, 580px);
  }
  .feat-panel {
    position: relative;
    flex: 1 1 0;
    min-width: 0;
    overflow: hidden;
    border-radius: 2px;
    background: var(--bg-elevated);
    transition: flex-grow 0.55s var(--ease);
  }
  /* When the row is hovered, non-hovered panels recede and the hovered one grows */
  .feat-panels:hover .feat-panel { flex-grow: 0.65; }
  .feat-panels .feat-panel:hover { flex-grow: 2.8; }

  .feat-panel-media { position: absolute; inset: 0; }
  .feat-panel-media :global(img) {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.9s var(--ease);
  }
  .feat-panel:hover .feat-panel-media :global(img) { transform: scale(1.04); }
  .feat-panel::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10, 10, 11, 0.85) 0%, rgba(10, 10, 11, 0.05) 55%);
    pointer-events: none;
  }
  .feat-panel-cap {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 2;
    padding: clamp(1rem, 1.6vw, 1.5rem);
  }
  .feat-panel-title {
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: -0.015em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .feat-panel:hover .feat-panel-title { color: var(--accent); }
  .feat-panel-meta {
    margin-top: 0.4rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.4s var(--ease), transform 0.4s var(--ease);
  }
  .feat-panel:hover .feat-panel-meta { opacity: 1; transform: none; }

  /* ---- Category tiles ---- */
  .cats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
  }
  .cat { position: relative; display: block; overflow: hidden; border-radius: 2px; }
  .cat-media { height: clamp(260px, 42vh, 400px); background: var(--bg-elevated); }
  .cat-media :global(img) {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 1s var(--ease);
  }
  .cat:hover .cat-media :global(img) { transform: scale(1.02); }
  .cat-overlay {
    position: absolute; inset-inline: 0; bottom: 0;
    display: flex; align-items: flex-end; justify-content: space-between; gap: 0.75rem;
    padding: clamp(1rem, 2vw, 1.5rem);
    background: linear-gradient(to top, rgba(10, 10, 11, 0.82), transparent);
  }
  .cat-name { font-size: var(--text-lg); letter-spacing: -0.015em; }
  .cat-sub { margin-top: 0.3rem; color: var(--text-secondary); font-size: var(--text-sm); }
  .cat-arrow {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    transition: transform 0.3s var(--ease), color 0.3s var(--ease);
  }
  .cat:hover .cat-arrow { transform: translateX(5px); color: var(--accent); }

  .home-cta { text-align: center; padding-block: clamp(3rem, 8vh, 5rem); }
  .cta-line { margin-top: 0.6rem; }
  .cta-line a { color: var(--text-secondary); }
  .cta-line a:hover { color: var(--accent); }

  @media (max-width: 1020px) {
    .cats { grid-template-columns: 1fr 1fr; }
    .cat-media { height: clamp(220px, 32vh, 320px); }
  }

  /* Stack the featured panels on narrow / touch screens (no hover to expand) */
  @media (max-width: 820px) {
    .feat-panels {
      display: grid;
      grid-template-columns: 1fr;
      height: auto;
      gap: 0.75rem;
    }
    .feat-panel { height: clamp(220px, 44vw, 300px); }
    .feat-panel-meta { opacity: 1; transform: none; }
    .feat-panel-title { white-space: normal; }
  }
  @media (max-width: 560px) {
    .cats { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cat-media :global(img),
    .feat-panel-media :global(img),
    .feat-panel,
    .hero-cue span { transition: none; animation: none; }
  }
</style>
