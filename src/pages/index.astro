---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import { asset } from '../lib/assets';
import { getCollection } from 'astro:content';

// Flagships — featured on the home page AND inside each category gallery
// they contribute to. Presented as portfolio cards (Julian's work), never
// styled as the client's own site.
const featured = (await getCollection('projects', ({ data }) => data.featured_home))
  .sort((a, b) => (a.data.home_order ?? 99) - (b.data.home_order ?? 99));

const labels = {
  videography: 'Videography',
  photography: 'Photography',
  'graphic-design': 'Graphic Design',
  'industrial-design': 'Industrial Design',
};
const span = (p) => p.data.disciplines.map((d) => labels[d]).join(' · ');

const categories = [
  {
    href: '/videography',
    label: 'Videography',
    sub: 'Cinematic · commercial · short form',
    cover: 'covers/videography-1',
    alt: 'Videography by Julian Saliby',
  },
  {
    href: '/photography',
    label: 'Photography',
    sub: 'Automotive · architectural · commercial',
    cover: 'covers/photo',
    alt: 'Photography by Julian Saliby',
  },
  {
    href: '/graphic-design',
    label: 'Graphic Design',
    sub: 'Identity · logo systems · print',
    cover: 'covers/graphic-design-posters',
    alt: 'Graphic design by Julian Saliby',
  },
  {
    href: '/industrial-design',
    label: 'Industrial Design',
    sub: 'Products · furniture · capstone',
    cover: 'covers/industrial-design-projects',
    alt: 'Industrial design by Julian Saliby',
  },
];
---

<Base>
  <!-- Intro -->
  <section class="container home-head">
    <h1 class="home-title">Julesfolio</h1>
    <p class="home-line">
      Industrial designer, photographer, and videographer — one eye for
      product, brand, and image, across every medium a project needs.
    </p>
  </section>

  <!-- Featured Work — the range story, deliberately spanning disciplines -->
  <section class="container section feat-section">
    <div class="feat-head">
      <p class="meta">Featured Work</p>
      <div class="feat-nav">
        <button type="button" class="feat-arrow" data-dir="-1" aria-label="Scroll featured work left">←</button>
        <button type="button" class="feat-arrow" data-dir="1" aria-label="Scroll featured work right">→</button>
      </div>
    </div>
    <div class="feat-track" id="feat-track">
      {featured.map((p, i) => (
        <a href={`/projects/${p.id}`} class="feat-card reveal">
          <figure class="feat-media">
            <Image
              src={asset(p.data.cover)}
              alt={`${p.data.title} — work by Julian Saliby`}
              widths={[500, 900, 1300]}
              sizes="(max-width: 640px) 80vw, (max-width: 1020px) 45vw, 30vw"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </figure>
          <div class="feat-caption">
            <h2 class="feat-title">{p.data.title}</h2>
            <p class="meta">{span(p)} · {p.data.year}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <script>
    const track = document.getElementById('feat-track');
    if (track) {
      document.querySelectorAll('.feat-arrow').forEach((btn) => {
        btn.addEventListener('click', () => {
          const dir = Number(btn.getAttribute('data-dir'));
          track.scrollBy({ left: dir * track.clientWidth * 0.85, behavior: 'smooth' });
        });
      });
    }
  </script>

  <!-- Browse by category — a clear path in for single-discipline visitors -->
  <section class="container section">
    <p class="meta" style="margin-bottom:1.5rem">Browse by category</p>
    <div class="cats">
      {categories.map((c) => (
        <a href={c.href} class="cat reveal">
          <figure class="cat-media">
            <Image src={asset(c.cover)} alt={c.alt} widths={[600, 900, 1200]} sizes="(max-width: 820px) 100vw, 25vw" loading="lazy" />
          </figure>
          <div class="cat-overlay">
            <div>
              <h2 class="cat-name">{c.label}</h2>
              <p class="cat-sub">{c.sub}</p>
            </div>
            <span class="cat-arrow" aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Quiet footer CTA -->
  <section class="container section home-cta reveal">
    <p class="meta">Julian Saliby — design · photo · film</p>
    <p class="cta-line">
      <a href="/about">About</a> · <a href="/contact">Get in touch</a>
    </p>
  </section>
</Base>

<style>
  .home-head { padding-top: clamp(7rem, 16vh, 10rem); padding-bottom: clamp(1rem, 2.5vh, 1.5rem); }
  .home-title { font-size: var(--text-hero); letter-spacing: -0.02em; }
  .home-line { margin-top: 1rem; color: var(--text-secondary); max-width: 52ch; font-size: var(--text-lg); line-height: 1.4; }

  /* Featured Work — pull this section closer to the intro than the default section rhythm */
  .feat-section { margin-top: clamp(1.5rem, 4vh, 3rem); }

  .feat-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  .feat-nav { display: flex; gap: 0.5rem; }
  .feat-arrow {
    display: flex; align-items: center; justify-content: center;
    width: 2.25rem; height: 2.25rem;
    border: 1px solid var(--border, rgba(255, 255, 255, 0.15));
    border-radius: 50%;
    background: transparent;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: color 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .feat-arrow:hover { color: var(--accent); border-color: var(--accent); }

  /* Featured Work carousel — four equal cards, scroll-snapped */
  .feat-track {
    display: flex;
    gap: clamp(1.25rem, 2.5vw, 2rem);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: var(--gutter);
    padding-bottom: 0.5rem;
    margin-bottom: -0.5rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .feat-track::-webkit-scrollbar { display: none; }
  .feat-card {
    flex: 0 0 clamp(260px, 30vw, 380px);
    display: block;
    scroll-snap-align: start;
  }
  .feat-media { overflow: hidden; background: var(--bg-elevated); aspect-ratio: 3 / 2; border-radius: 2px; }
  .feat-media :global(img) {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.7s var(--ease);
  }
  .feat-card:hover .feat-media :global(img) { transform: scale(1.025); }
  .feat-caption { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-top: 0.9rem; }
  .feat-title { font-size: var(--text-base); font-weight: 600; letter-spacing: -0.01em; }
  .feat-card:hover .feat-title { color: var(--accent); }

  /* Category tiles */
  .cats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
  }
  .cat { position: relative; display: block; overflow: hidden; border-radius: 2px; }
  .cat-media { height: clamp(260px, 42vh, 400px); background: var(--bg-elevated); }
  .cat-media :global(img) {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 1s var(--ease);
  }
  .cat:hover .cat-media :global(img) { transform: scale(1.02); }
  .cat-overlay {
    position: absolute; inset-inline: 0; bottom: 0;
    display: flex; align-items: flex-end; justify-content: space-between; gap: 0.75rem;
    padding: clamp(1rem, 2vw, 1.5rem);
    background: linear-gradient(to top, rgba(10, 10, 11, 0.82), transparent);
  }
  .cat-name { font-size: var(--text-lg); letter-spacing: -0.015em; }
  .cat-sub { margin-top: 0.3rem; color: var(--text-secondary); font-size: var(--text-sm); }
  .cat-arrow {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    transition: transform 0.3s var(--ease), color 0.3s var(--ease);
  }
  .cat:hover .cat-arrow { transform: translateX(5px); color: var(--accent); }

  .home-cta { text-align: center; padding-block: clamp(3rem, 8vh, 5rem); }
  .cta-line { margin-top: 0.6rem; }
  .cta-line a { color: var(--text-secondary); }
  .cta-line a:hover { color: var(--accent); }

  @media (max-width: 1020px) {
    .cats { grid-template-columns: 1fr 1fr; }
    .cat-media { height: clamp(220px, 32vh, 320px); }
  }
  @media (max-width: 820px) {
    .feat-card { flex-basis: 82vw; }
  }
  @media (max-width: 560px) {
    .cats { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cat-media :global(img), .feat-media :global(img) { transition: none; }
  }
</style>
