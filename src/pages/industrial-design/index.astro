---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { asset, hasAsset } from '../../lib/assets';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const order = { hero: 0, featured: 1, standard: 2, minor: 3 };
const projects = (await getCollection('projects', ({ data }) => data.disciplines.includes('industrial-design')))
  .sort((a, b) => order[a.data.weight] - order[b.data.weight] || b.data.year - a.data.year);

// Rebuilding project-by-project from the old site; covers shown now, pages next.
const items = [
  { title: 'Balco Furniture Piece', year: 2024, cover: 'covers/furniture' },
  { title: 'Inferno Fire Extinguisher', year: 2022, cover: 'covers/inferno-fire-extinguisher' },
  { title: 'Product Brand Extension', year: 2022, cover: 'covers/product-brand-extension' },
  { title: 'Walkie Talkie Redesign', year: 2022, cover: 'covers/walkie-talkie-redesign' },
  { title: 'Portable Tool Belt', year: 2022, cover: 'covers/portable-tool-belt' },
  { title: 'Winter Skateboard', year: 2022, cover: 'covers/winter-skateboard' },
].filter((i) => hasAsset(i.cover));
---

<Base title="Industrial Design">
  <header class="container gallery-head">
    <p class="meta">Category</p>
    <h1>Industrial Design</h1>
    <p class="lede">Carleton University B.I.D. work — full case studies being rebuilt for this site.</p>
  </header>

  {projects.length > 0 && (
    <section class="container featured">
      <p class="meta" style="margin-bottom:1.25rem">Featured</p>
      <div class="feat-grid">
        {projects.map((p) => (
          <ProjectCard large={p.data.weight !== 'minor'} href={`/projects/${p.id}`} title={p.data.title} meta={`${p.data.year}`} cover={p.data.cover} />
        ))}
      </div>
    </section>
  )}

  <section class="container grid">
    {items.map((u) => (
      <div class="card-soon reveal">
        <figure class="soon-media">
          <Image src={asset(u.cover)} alt={u.title} widths={[600, 1200]} sizes="(max-width: 820px) 100vw, 33vw" />
        </figure>
        <div class="soon-caption">
          <h3 class="soon-title">{u.title}</h3>
          <p class="meta">{u.year} · Coming soon</p>
        </div>
      </div>
    ))}
  </section>
</Base>

<style>
  .gallery-head { padding-top: 8rem; }
  .gallery-head h1 { font-size: var(--text-2xl); margin-block: 0.5rem 1rem; }
  .lede { color: var(--text-secondary); max-width: 52ch; }
  .featured { margin-top: 3rem; }
  .feat-grid { display: grid; gap: clamp(1.5rem, 3vw, 2.5rem); }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1.25rem, 2.5vw, 2rem); margin-top: 3rem; }
  .card-soon { opacity: 0.6; }
  .soon-media { overflow: hidden; background: var(--bg-elevated); aspect-ratio: 4 / 3; }
  .soon-media :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .soon-caption { margin-top: 0.8rem; }
  .soon-title { font-size: var(--text-base); font-weight: 600; }
  @media (max-width: 820px) { .grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .grid { grid-template-columns: 1fr; } }
</style>
