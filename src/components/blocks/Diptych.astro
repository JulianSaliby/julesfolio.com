---
import { Image } from 'astro:assets';
import { asset } from '../../lib/assets';

interface Props { images: string[]; alts?: string[]; }
const { images, alts = [] } = Astro.props;
const cols = Math.min(images.length, 3);
---

<section class:list={['container', 'tych', `cols-${cols}`, 'section', 'reveal']}>
  {images.map((img, i) => (
    <figure><Image src={asset(img)} alt={alts[i] ?? ''} widths={[720, 1200]} sizes={`(max-width: 820px) 100vw, ${Math.round(100 / cols)}vw`} /></figure>
  ))}
</section>

<style>
  .tych { display: grid; gap: clamp(0.75rem, 2vw, 1.5rem); }
  .cols-2 { grid-template-columns: 1fr 1fr; }
  .cols-3 { grid-template-columns: 1fr 1fr 1fr; }
  .tych figure { overflow: hidden; }
  .tych :global(img) { width: 100%; height: 100%; object-fit: cover; }
  @media (max-width: 680px) { .cols-2, .cols-3 { grid-template-columns: 1fr; } }
</style>
