---
interface Props {
  title: string;
  meta?: string;
  roles?: string[];
}
const { title, meta, roles = [] } = Astro.props;
---

<header class="container project-intro">
  <div class="intro-grid">
    <div>
      {meta && <p class="meta">{meta}</p>}
      <h1 class="project-title">{title}</h1>
    </div>
    <div class="intro-side">
      {roles.length > 0 && (
        <ul class="roles">
          {roles.map((r) => <li class="meta">{r}</li>)}
        </ul>
      )}
      <div class="intro-body"><slot /></div>
    </div>
  </div>
</header>

<style>
  /* Bottom padding intentionally omitted — the next block is always a
     `.section`, whose own margin-top already provides the gap. Adding
     padding here on top of that stacked into an oversized gap. */
  .project-intro { padding-block: clamp(1.75rem, 4.5vh, 3.25rem) 0; }
  .intro-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: clamp(2rem, 5vw, 5rem); align-items: end; }
  .project-title { font-size: var(--text-2xl); margin-top: 0.6rem; }
  .roles { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem 1.2rem; margin-bottom: 1rem; }
  .intro-body { color: var(--text-secondary); }
  .intro-body :global(p + p) { margin-top: 0.8em; }
  @media (max-width: 820px) { .intro-grid { grid-template-columns: 1fr; align-items: start; } }
</style>
