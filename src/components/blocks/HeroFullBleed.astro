---
import { Image } from 'astro:assets';
import { asset } from '../../lib/assets';

interface Props {
  image: string; // extension-less asset path
  title?: string;
  meta?: string;
  alt?: string;
  height?: 'full' | 'tall' | 'medium';
}
const { image, title, meta, alt = title ?? '', height = 'tall' } = Astro.props;
---

<section class:list={['hero-bleed', `h-${height}`]}>
  <Image src={asset(image)} alt={alt} class="hero-img" widths={[768, 1440, 1920]} sizes="100vw" loading="eager" />
  {(title || meta) && (
    <div class="hero-overlay">
      <div class="container">
        {meta && <p class="meta hero-meta">{meta}</p>}
        {title && <h1 class="hero-title">{title}</h1>}
      </div>
    </div>
  )}
</section>

<style>
  .hero-bleed { position: relative; overflow: hidden; }
  .h-full { height: 100svh; }
  .h-tall { height: 82svh; }
  .h-medium { height: 60svh; }
  .hero-img { width: 100%; height: 100%; object-fit: cover; }
  .hero-overlay {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding-block: clamp(2rem, 6vh, 4rem);
    background: linear-gradient(to top, rgba(10, 10, 11, 0.72), transparent);
  }
  .hero-title { font-size: var(--text-hero); }
  .hero-meta { margin-bottom: 0.75rem; color: var(--text-secondary); }
</style>
