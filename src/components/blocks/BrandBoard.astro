---
import { Image } from 'astro:assets';
import { asset, assetsIn } from '../../lib/assets';
import type { ImageMetadata } from 'astro';

interface Props {
  dir?: string;
  images?: string[];
  caption?: string;
}
const { dir, images, caption } = Astro.props;
const list: ImageMetadata[] = dir ? assetsIn(dir) : (images ?? []).map(asset);
---

<section class="container brand-board section reveal">
  {caption && <p class="meta" style="margin-bottom:1.25rem">{caption}</p>}
  <div class="board">
    {list.map((img) => (
      <figure><Image src={img} alt="" widths={[600, 1000]} sizes="(max-width: 820px) 50vw, 33vw" /></figure>
    ))}
  </div>
</section>

<style>
  .board {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
  }
  .board figure { background: var(--bg-elevated); overflow: hidden; }
  .board :global(img) { width: 100%; height: 100%; object-fit: cover; }
</style>
