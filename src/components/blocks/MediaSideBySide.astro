---
import { Image } from 'astro:assets';
import { asset } from '../../lib/assets';

interface Props {
  image: string;
  image2?: string; // second image instead of text slot
  alt?: string;
  alt2?: string;
  flip?: boolean; // media on the right
  title?: string;
}
const { image, image2, alt = '', alt2 = '', flip = false, title } = Astro.props;
---

<section class:list={['container', 'side', { flip }, 'section', 'reveal']}>
  <figure><Image src={asset(image)} alt={alt} widths={[720, 1200]} sizes="(max-width: 820px) 100vw, 50vw" /></figure>
  {image2 ? (
    <figure><Image src={asset(image2)} alt={alt2} widths={[720, 1200]} sizes="(max-width: 820px) 100vw, 50vw" /></figure>
  ) : (
    <div class="side-text">
      {title && <h2>{title}</h2>}
      <div class="side-body"><slot /></div>
    </div>
  )}
</section>

<style>
  .side {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 3vw, 2.5rem);
    align-items: center;
  }
  .side.flip figure:first-of-type { order: 2; }
  .side-text h2 { font-size: var(--text-xl); margin-bottom: 1rem; }
  .side-body { color: var(--text-secondary); max-width: 46ch; }
  .side-body :global(p + p) { margin-top: 0.9em; }
  @media (max-width: 820px) {
    .side { grid-template-columns: 1fr; }
    .side.flip figure:first-of-type { order: 0; }
  }
</style>
