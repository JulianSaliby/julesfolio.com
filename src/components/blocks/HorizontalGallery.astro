---
import { Image } from 'astro:assets';
import { asset, assetsIn } from '../../lib/assets';
import type { ImageMetadata } from 'astro';

interface Props {
  dir?: string;      // take every image in this asset dir…
  images?: string[]; // …or an explicit ordered list
  caption?: string;
}
const { dir, images, caption } = Astro.props;
const list: ImageMetadata[] = dir ? assetsIn(dir) : (images ?? []).map(asset);
const uid = `fs-${Math.random().toString(36).slice(2, 9)}`;
---

<section class="filmstrip-wrap section reveal">
  <div class="filmstrip-head container">
    {caption && <p class="meta filmstrip-caption">{caption}</p>}
    <div class="filmstrip-controls" data-filmstrip-controls={uid}>
      <button type="button" class="fs-btn fs-prev" aria-label="Previous photo" data-dir="-1">←</button>
      <span class="fs-count" data-fs-count>1 / {list.length}</span>
      <button type="button" class="fs-btn fs-next" aria-label="Next photo" data-dir="1">→</button>
    </div>
  </div>
  <div class="filmstrip" id={uid} tabindex="0" role="region" aria-label={caption ?? 'Image gallery'}>
    {list.map((img) => (
      <figure><Image src={img} alt="" widths={[500, 900]} sizes="46vh" /></figure>
    ))}
  </div>
</section>

<script>
  function initFilmstrips() {
    document.querySelectorAll<HTMLElement>('.filmstrip').forEach((strip) => {
      const id = strip.id;
      const controls = document.querySelector<HTMLElement>(`[data-filmstrip-controls="${id}"]`);
      if (!controls || strip.dataset.fsBound) return;
      strip.dataset.fsBound = '1';

      const countEl = controls.querySelector<HTMLElement>('[data-fs-count]');
      const figures = Array.from(strip.querySelectorAll('figure'));
      const total = figures.length;

      const currentIndex = () => {
        const center = strip.scrollLeft + strip.clientWidth / 2;
        let closest = 0;
        let best = Infinity;
        figures.forEach((f, i) => {
          const mid = (f as HTMLElement).offsetLeft + (f as HTMLElement).offsetWidth / 2;
          const d = Math.abs(mid - center);
          if (d < best) { best = d; closest = i; }
        });
        return closest;
      };

      const updateCount = () => {
        if (countEl) countEl.textContent = `${currentIndex() + 1} / ${total}`;
      };

      controls.querySelectorAll<HTMLButtonElement>('.fs-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const dir = Number(btn.dataset.dir);
          const target = Math.min(total - 1, Math.max(0, currentIndex() + dir));
          const f = figures[target] as HTMLElement;
          strip.scrollTo({ left: f.offsetLeft - (strip.clientWidth - f.offsetWidth) / 2, behavior: 'smooth' });
        });
      });

      strip.addEventListener('scroll', () => {
        window.clearTimeout((strip as any)._fsTimer);
        (strip as any)._fsTimer = window.setTimeout(updateCount, 80);
      }, { passive: true });

      updateCount();
    });
  }
  document.addEventListener('astro:page-load', initFilmstrips);
  initFilmstrips();
</script>

<style>
  .filmstrip-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .filmstrip-caption { margin: 0; }
  .filmstrip-controls { display: flex; align-items: center; gap: 0.75rem; flex: none; }
  .fs-count { font-size: var(--text-xs); color: var(--text-tertiary); min-width: 3.5em; text-align: center; }
  .fs-btn {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    border: 1px solid var(--hairline);
    background: var(--bg-elevated);
    color: var(--text-secondary);
    cursor: pointer;
    transition: color 0.25s var(--ease), border-color 0.25s var(--ease), background 0.25s var(--ease);
  }
  .fs-btn:hover { color: var(--text); border-color: var(--text-tertiary); background: var(--bg-subtle); }

  .filmstrip {
    display: flex;
    gap: clamp(0.6rem, 1.2vw, 1rem);
    overflow-x: auto;
    padding-inline: var(--gutter);
    scroll-snap-type: x proximity;
    scrollbar-width: none;
  }
  .filmstrip::-webkit-scrollbar { display: none; }
  .filmstrip figure { flex: 0 0 auto; scroll-snap-align: start; }
  .filmstrip :global(img) { height: min(46vh, 400px); width: auto; }

  @media (max-width: 640px) {
    .filmstrip-controls { display: none; }
  }
</style>
