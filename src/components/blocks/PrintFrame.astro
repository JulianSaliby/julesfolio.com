---
import { Image } from 'astro:assets';
import { asset } from '../../lib/assets';

interface Props {
  image: string;
  alt?: string;
  caption?: string;
  pdf?: string; // optional public/ path to downloadable PDF
}
const { image, alt = '', caption, pdf } = Astro.props;
---

<section class="print-frame section reveal">
  <figure>
    <Image src={asset(image)} alt={alt} widths={[720, 1200]} sizes="(max-width: 820px) 92vw, 60vw" />
    {(caption || pdf) && (
      <figcaption class="meta">
        {caption}
        {pdf && <a href={pdf} target="_blank" rel="noopener" class="pdf-link">View PDF ↗</a>}
      </figcaption>
    )}
  </figure>
</section>

<style>
  .print-frame { display: grid; place-items: center; padding-inline: var(--gutter); }
  .print-frame figure { max-width: 760px; }
  .print-frame figcaption { margin-top: 1rem; display: flex; gap: 1.5rem; justify-content: center; }
  .pdf-link { color: var(--accent); }
</style>
