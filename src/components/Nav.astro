---
const links = [
  { href: '/videography', label: 'Videography' },
  { href: '/photography', label: 'Photography' },
  { href: '/graphic-design', label: 'Graphic Design' },
  { href: '/industrial-design', label: 'Industrial Design' },
  { href: '/about', label: 'About' },
];
const path = Astro.url.pathname;
---

<header class="site-nav">
  <nav class="container nav-inner" aria-label="Main">
    <a href="/" class="wordmark">Julian Saliby</a>
    <ul class="nav-links">
      {links.map((l) => (
        <li>
          <a href={l.href} aria-current={path.startsWith(l.href) ? 'page' : undefined}>{l.label}</a>
        </li>
      ))}
      <li><a href="/contact" class="nav-contact">Contact</a></li>
    </ul>
  </nav>
</header>

<style>
  .site-nav {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 100;
    transition: background 0.35s var(--ease), border-color 0.35s var(--ease);
    border-bottom: 1px solid transparent;
  }
  .site-nav.is-scrolled {
    background: rgba(10, 10, 11, 0.72);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
    border-bottom-color: var(--hairline);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }
  .wordmark {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .nav-links {
    display: flex;
    gap: 1.75rem;
    list-style: none;
    font-size: var(--text-sm);
  }
  .nav-links a { color: var(--text-secondary); }
  .nav-links a:hover, .nav-links a[aria-current='page'] { color: var(--text); }
  .nav-contact { color: var(--text) !important; }

  @media (max-width: 820px) {
    .nav-links { gap: 1.1rem; overflow-x: auto; }
    .nav-inner { height: 3.25rem; }
  }
</style>
