---
import { Image } from 'astro:assets';
import { asset } from '../lib/assets';

interface Props {
  href: string;
  title: string;
  meta: string;
  cover: string;
  large?: boolean;
}
const { href, title, meta, cover, large = false } = Astro.props;
---

<a href={href} class:list={['card', { large }, 'reveal']}>
  <figure class="card-media">
    <Image src={asset(cover)} alt={title} widths={[600, 1200, 1800]} sizes={large ? '100vw' : '(max-width: 820px) 100vw, 50vw'} />
  </figure>
  <div class="card-caption">
    <h3 class="card-title">{title}</h3>
    <p class="meta">{meta}</p>
  </div>
</a>

<style>
  .card { display: block; }
  .card-media { overflow: hidden; background: var(--bg-elevated); aspect-ratio: 3 / 2; }
  .card.large .card-media { aspect-ratio: 16 / 9; }
  .card-media :global(img) {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.7s var(--ease);
  }
  .card:hover .card-media :global(img) { transform: scale(1.025); }
  .card-caption { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-top: 0.9rem; }
  .card-title { font-size: var(--text-base); font-weight: 600; letter-spacing: -0.01em; }
  .card:hover .card-title { color: var(--accent); }
  @media (prefers-reduced-motion: reduce) { .card-media :global(img) { transition: none; } }
</style>
